{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.mts",
    "src/agentic_tools/**/*.ts"
  ]
}