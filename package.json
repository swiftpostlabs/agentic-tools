{
  "name": "agentic-tools",
  "version": "0.1.0",
  "description": "Shared agent skills and CLI tools for Node-based repositories.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agents-policy": "./node/bin/agents-policy.js",
    "agents-policy-import-vscode": "./node/bin/agents-policy-import-vscode.js",
    "sync-ai-policy": "./node/bin/agents-policy.js",
