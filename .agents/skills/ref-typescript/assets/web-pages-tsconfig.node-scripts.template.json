{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.js",
    "scripts/**/*.mjs",
    "scripts/**/*.cjs",
    "scripts/**/*.mts",
    "scripts/**/*.ts",
    "scripts/**/*.cts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist"
  ]
}
