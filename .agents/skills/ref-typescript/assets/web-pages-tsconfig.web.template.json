{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": []
  },
  "include": [
    "src/features/**/*.js",
    "src/features/**/*.mjs"
  ],
  "exclude": [
