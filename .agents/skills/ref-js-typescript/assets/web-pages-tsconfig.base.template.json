{
  "compilerOptions": {
    "target": "ES2022",
    "allowJs": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "DOM.AsyncIterable",
      "deno.ns"
    ],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  }
}
