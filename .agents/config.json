{
  "policy": {
    "services": [
      "gemini",
      "claude",
      "copilot"
    ],
    "protectedFiles": [
      "*.env",
      "*.env.*",
      "*.pem",
      "*.key",
      "*.pub",
      "credentials.json",
      "secrets/",
      "internal-config.yml"
    ],
    "excludedFiles": [
      "**/node_modules/",
      "**/.next/",
      "dist/",
      "build/",
      "out/",
      "*.log",
      "*.tmp",
      "*.bak",
      "tmp/",
      "temp/",
      "logs/",
      ".turbo/"
    ],
    "terminalAutoApprove": {
      "/^git (log|status|diff).*$/": true,
      "/^uv run poe (lint|lint-fix|typecheck|test)$/": true,
      "/^uv run agentic-tools policy (sync|check|import-vscode)$/": true,
      "/^uv run (agents-policy|agents-policy-import-vscode|sync-ai-policy|sync-ai-policy-import-vscode)$/": true,
      "rm": false,
      "rmdir": false,
      "del": false,
      "curl": false,
      "wget": false,
      "uv": true,
      "Out-Null": true
    },
    "editAutoApprove": {
      "**/*.{py,json,yml,yaml,css,md}": true,
      "**/.env*": false,
      "**/secrets/**": false,
      "**/.aiexclude": false,
      "**/.agents/config.json": false,
      "**/.agents/policy.json": false,
      "**/*.{pem,key,pub}": false,
      "**/internal-config.yml": false
    }
  }
}
