{
  "policy": {
    "services": [
      "gemini",
      "claude",
      "copilot"
    ],
    "protectedFiles": [
      "*.env",
      "*.env.*",
      "*.pem",
      "*.key",
      "*.pub",
      "credentials.json",
      "secrets/",
      "internal-config.yml"
    ],
    "excludedFiles": [
      "**/node_modules/",
      "**/.next/",
      "dist/",
      "build/",
      "out/",
      "*.log",
      "*.tmp",
      "*.bak",
      "tmp/",
      "temp/",
      "logs/",
      ".turbo/"
    ],
    "terminalAutoApprove": {
      "/^git (log|status|diff).*$/": true,
      "/^uv run poe (lint|lint-fix|typecheck|test)$/": true,
      "/^uv run agentic-tools policy (sync|check|import-vscode)$/": true,
      "rm": false,
      "rmdir": false,
      "del": false,
      "curl": false,
      "wget": false,
      "uv": true,
      "Out-Null": true
    },
    "editAutoApprove": {
      "**/*.{py,json,yml,yaml,css,md}": true,
      "**/.env*": false,
      "**/secrets/**": false,
      "**/.aiexclude": false,
      "**/.agents/config.json": false,
      "**/.agents/policy.json": false,
      "**/*.{pem,key,pub}": false,
      "**/internal-config.yml": false
    }
  },
  "plugin": {
    "name": "agentic-tools",
    "displayName": "Agentic Tools",
    "description": "Shared agent skills for repo conventions, coding practice, databases, and agent tooling.",
    "category": "productivity",
    "license": "MIT",
    "repository": "https://github.com/swiftpostlabs/agentic-tools",
    "keywords": ["skills", "agents", "conventions"],
    "skillsRoot": ".agents/skills",
    "publishVisibility": ["public"],
    "marketplace": {
      "name": "swiftpostlabs",
      "owner": {
        "name": "SwiftPost Labs",
        "url": "https://github.com/swiftpostlabs"
      }
    }
  }
}
