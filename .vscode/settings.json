{
  "files.associations": {
    "*.env": "copilot-restricted-file",
    "*.env.*": "copilot-restricted-file",
    "*.pem": "copilot-restricted-file",
    "*.key": "copilot-restricted-file",
    "*.pub": "copilot-restricted-file",
    "credentials.json": "copilot-restricted-file",
    "secrets/": "copilot-restricted-file",
    "internal-config.yml": "copilot-restricted-file"
  },
  "github.copilot.enable": {
    "copilot-restricted-file": false
  },
  "chat.tools.terminal.autoApprove": {
    "/^git (log|status|diff).*$/": true,
    "/^uv run poe (lint|lint-fix|typecheck|test)$/": true,
    "/^uv run agentic-tools policy (sync|check|import-vscode)$/": true,
    "rm": false,
    "rmdir": false,
    "del": false,
    "curl": false,
    "wget": false,
    "uv": true,
    "Out-Null": true
  },
  "chat.tools.edits.autoApprove": {
    "**/*.{py,json,yml,yaml,css,md}": true,
    "**/.env*": false,
    "**/secrets/**": false,
    "**/.aiexclude": false,
    "**/.agents/config.json": false,
    "**/.agents/policy.json": false,
    "**/*.{pem,key,pub}": false,
    "**/internal-config.yml": false
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "editor.formatOnSave": true,
  "editor.autoIndent": "advanced",
  "editor.guides.indentation": true,
  "editor.tabSize": 2,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4
  },
  "python.analysis.autoFormatStrings": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.autoImportCompletions": true,
  "python.languageServer": "Pylance",
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "files.exclude": {
    "**/node_modules": true,
    ".venv": true,
    "venv": true,
    "__pycache__": true,
    ".env": true,
    ".env.*": true,
    "dist": true,
    "build": true,
    "**/.agent": false
  },
  "cSpell.words": [
    "agentic",
    "cooldown",
    "swiftpostlabs"
  ]
}
